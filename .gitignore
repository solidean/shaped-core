# ─── Build output ───────────────────────────────────────────
bin/
build/
build_vs/
build-vs/
target/            # rust

# ─── Compiled artifacts ─────────────────────────────────────
# Object files
*.o
*.obj
*.slo
*.lo
# Precompiled headers
*.gch
*.pch
# Dynamic libraries
*.so
*.dylib
*.dll
# Static libraries
*.a
*.la
*.lai
*.lib
# Fortran modules
*.mod
*.smod
# Executables
*.exe
*.out
*.app
# Prerequisites / dependency files
*.d
# Coverage / PGO raw profiles (LLVM)
*.profraw

# ─── CMake ──────────────────────────────────────────────────
CMakeLists.txt.user        # qtcreator
CMakeUserPresets.json      # user-local presets
compile_commands.json      # emitted by generator, consumed by clangd

# ─── Editors & IDEs ─────────────────────────────────────────
.vscode
.vs/
*.code-workspace
.clj-kondo
.lsp
.cache/                    # used by clangd

# ─── Languages ──────────────────────────────────────────────
# rust
Cargo.lock
# python (uv-run helper scripts)
__pycache__/
*.pyc

# ─── Vendored dependencies ──────────────────────────────────
.clone/                    # transient shallow clone made by extern/*/vendor-*.py

# ─── Misc ───────────────────────────────────────────────────
imgui.ini                  # workdir spam
*.DS_Store                 # macos

# ─── Explicitly committed binary tools ─────────────────────
# Checked in on purpose; re-included despite the build/binary rules above.
!tools/bin/
!tools/bin/**
