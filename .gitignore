# NOTE: git does NOT support inline (trailing) comments in .gitignore. Only a line whose FIRST
# non-space character is `#` is a comment; a `# ...` placed after a pattern becomes part of the
# pattern (along with the spaces before it), so e.g. `foo/   # bar` matches nothing. Keep every
# comment on its own line and every pattern clean.

# ─── Build output ───────────────────────────────────────────
bin/
build/
build_vs/
build-vs/
# rust
target/

# ─── Compiled artifacts ─────────────────────────────────────
# Object files
*.o
*.obj
*.slo
*.lo
# Precompiled headers
*.gch
*.pch
# Dynamic libraries
*.so
*.dylib
*.dll
# Static libraries
*.a
*.la
*.lai
*.lib
# Fortran modules
*.mod
*.smod
# Executables
*.exe
*.out
*.app
# Prerequisites / dependency files
*.d
# Coverage / PGO raw profiles (LLVM)
*.profraw

# ─── CMake ──────────────────────────────────────────────────
# qtcreator
CMakeLists.txt.user
# user-local presets
CMakeUserPresets.json
# emitted by generator, consumed by clangd
compile_commands.json

# ─── Editors & IDEs ─────────────────────────────────────────
.vscode
.vs/
*.code-workspace
.clj-kondo
.lsp
# used by clangd
.cache/

# ─── Languages ──────────────────────────────────────────────
# rust
Cargo.lock
# python (uv-run helper scripts)
__pycache__/
*.pyc

# ─── Vendored dependencies ──────────────────────────────────
# transient shallow clone made by extern/*/vendor-*.py
.clone/

# ─── Misc ───────────────────────────────────────────────────
# workdir spam
imgui.ini
# macos
*.DS_Store
# local scratch: handover notes, throwaway experiments
.tmp/

# ─── Explicitly committed binary tools ─────────────────────
# Checked in on purpose; re-included despite the build/binary rules above.
!tools/bin/
!tools/bin/**
