<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>nexus — @NEXUS_WEB_TITLE@</title>
<style>
  :root {
    --bg: #0d1117; --panel: #161b22; --border: #30363d; --fg: #c9d1d9; --muted: #8b949e;
    --green: #3fb950; --red: #f85149; --accent: #58a6ff;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; padding: 24px; background: var(--bg); color: var(--fg);
    font: 14px/1.5 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  h1 { margin: 0 0 4px; font-size: 18px; }
  .sub { color: var(--muted); margin-bottom: 16px; }
  .summary {
    display: flex; flex-wrap: wrap; gap: 20px; padding: 14px 16px; margin-bottom: 16px;
    background: var(--panel); border: 1px solid var(--border); border-radius: 8px;
  }
  .stat { display: flex; flex-direction: column; }
  .stat .label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: .05em; }
  .stat .value { font-size: 20px; font-weight: 600; }
  .value.pass { color: var(--green); } .value.fail { color: var(--red); }
  .bar { height: 6px; border-radius: 3px; background: var(--border); overflow: hidden; margin-bottom: 16px; }
  .bar > span { display: block; height: 100%; width: 0; background: var(--accent); transition: width .08s linear; }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 6px 10px; border-bottom: 1px solid var(--border); }
  th { color: var(--muted); font-weight: 600; font-size: 12px; position: sticky; top: 0; background: var(--bg); }
  td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }
  tr.group td { background: var(--panel); color: var(--accent); font-weight: 600; border-top: 2px solid var(--border); }
  tr.group .sub { color: var(--muted); font-weight: 400; font-size: 12px; }
  tr.pass td.status { color: var(--green); }
  tr.fail td.status { color: var(--red); }
  tr.fail { background: rgba(248, 81, 73, 0.08); }
  .report { color: var(--red); white-space: pre-wrap; font-size: 12px; padding: 2px 10px 8px 34px; }
  .name { color: var(--fg); }
</style>
</head>
<body>
  <h1>nexus — @NEXUS_WEB_TITLE@</h1>
  <div class="sub" id="subtitle">loading WebAssembly…</div>

  <div class="summary">
    <div class="stat"><span class="label">Progress</span><span class="value" id="s-progress">0 / 0</span></div>
    <div class="stat"><span class="label">Passed</span><span class="value pass" id="s-passed">0</span></div>
    <div class="stat"><span class="label">Failed</span><span class="value fail" id="s-failed">0</span></div>
    <div class="stat"><span class="label">Checks</span><span class="value" id="s-checks">0</span></div>
    <div class="stat"><span class="label">Elapsed (test time)</span><span class="value" id="s-time">0.0 ms</span></div>
  </div>
  <div class="bar"><span id="bar"></span></div>

  <table>
    <thead>
      <tr><th class="num">#</th><th>Test</th><th>Status</th><th class="num">Checks</th><th class="num">Time</th></tr>
    </thead>
    <tbody id="rows"></tbody>
  </table>

  <script>
    // Injected by CMake (sc_finalize_web_runners): the library modules this page should load and run.
    window.NEXUS_WEB_TITLE = "@NEXUS_WEB_TITLE@";
    window.NEXUS_WEB_MODULES = @NEXUS_WEB_MODULES_JS@;
  </script>
  <script src="nexus-web-driver.js"></script>
</body>
</html>
