# Style file for clang-format ( http://clang.llvm.org/docs/ClangFormatStyleOptions.html )
# Current style version: 2026-06-24
# Requires: clang-format >= 21 (config uses modern, non-deprecated option spellings)

# Changelog:
#   2026-06-24 - AllowShortCaseLabelsOnASingleLine off (case statement on its own
#                line); IndentCaseBlocks made explicit (brace at the `case` level)
#   2026-06-22 - custom brace wrapping, ReflowComments off, explicit BinPackArguments,
#                InsertNewlineAtEOF, modernized deprecated option spellings, require v21
#   2025-12-13 - column limit 120, penalty 10
#   2025-12-12 - AlignOperands, AllowAllArgumentsOnNextLine, AllowAllParametersOfDeclarationOnNextLine
#                AllowShortFunctionsOnASingleLine -> inline only
#   2025-12-10 - initial version

# rough grounding, most is custom
BasedOnStyle: Google
#Language: Cpp
Standard: Latest


# columns guideline
ColumnLimit: 120
PenaltyExcessCharacter: 10
PenaltyBreakString: 50


# Indentation and Braces
IndentWidth: 4
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
AllowShortFunctionsOnASingleLine: InlineOnly
AllowShortCaseLabelsOnASingleLine: false
AllowAllArgumentsOnNextLine: false # if args on next line, all multiline
AllowAllParametersOfDeclarationOnNextLine: false
AlwaysBreakBeforeMultilineStrings: false
BreakTemplateDeclarations: Yes
BreakBeforeBinaryOperators: All
BreakBeforeTernaryOperators: true
BreakBeforeConceptDeclarations: Always
BreakConstructorInitializers: BeforeColon
PackConstructorInitializers: NextLine
Cpp11BracedListStyle: true
IndentCaseLabels: false
# Non-trivial cases (with a `{}` block) keep the brace at the `case` level, not
# indented one step further. Combined with BraceWrapping.AfterCaseLabel below.
IndentCaseBlocks: false
RequiresClausePosition: OwnLine

# Allman braces, but spelled out as Custom so individual cases are tweakable.
# The values below reproduce Allman exactly except where we deviate deliberately.
BreakBeforeBraces: Custom
BraceWrapping:
    AfterCaseLabel: true
    AfterClass: true
    AfterControlStatement: Always
    AfterEnum: true
    AfterExternBlock: true
    AfterFunction: true
    AfterNamespace: true
    AfterStruct: true
    AfterUnion: true
    BeforeCatch: true
    BeforeElse: true
    BeforeLambdaBody: true
    BeforeWhile: false
    IndentBraces: false
    SplitEmptyFunction: true
    SplitEmptyRecord: true
    SplitEmptyNamespace: true

# Parameters and arguments are intentionally asymmetric:
#   Parameters are homogeneous (type + name). When a declaration overflows, one
#   parameter per line reads cleanly and stays scannable.
#   Arguments are heterogeneous (bare vars, literals, arbitrary expressions), so
#   bin-packing adapts better; one-arg-per-line gets needlessly verbose. Where a
#   specific layout aids readability we force it with trailing // comments.
BinPackParameters: OnePerLine
BinPackArguments: true


# Alignment
AlignOperands: AlignAfterOperator


# Spaces
DerivePointerAlignment: false
PointerAlignment: Left
MaxEmptyLinesToKeep: 2
SpaceBeforeParens: ControlStatements
SpaceBeforeAssignmentOperators: true
SpacesBeforeTrailingComments: 1
SpacesInAngles: Never
SpacesInParens: Never
SpacesInSquareBrackets: false
UseTab: Never
ConstructorInitializerIndentWidth: 2
AccessModifierOffset: -4


# Comments
# never auto-break comments; we format them deliberately
FixNamespaceComments: true
AlignTrailingComments:
    Kind: Always
    OverEmptyLines: 0
ReflowComments: false
InsertNewlineAtEOF: true


# Includes are grouped by "distance": local file, project headers,
# external library headers, then the standard library. This ordering
# improves include hygiene: headers pulled in close to the current file
# are least likely to hide missing dependencies in other headers, while
# project-wide and external includes follow in widening rings. When a
# header forgets to include something it depends on, this grouping makes
# the failure appear earlier and prevents accidental masking.
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  - Regex:  '^"'
    Priority: 1
  - Regex: '^<.*\.(h|hh|hpp|hxx)>'  # <foo/bar/file.h>, <x.hh>, ...
    Priority: 2
  - Regex: '^<'                     # stdlib
    Priority: 3


# We use east const (`T const`) via `QualifierAlignment: Right`.
# In modern C++, any name used as a type must behave like a real type alias.
# The only known semantic changes triggered by this option arise from
# macro-typedefs such as `#define P int*`, where `const P a` and `P const a`
# do not denote the same type. This discrepancy does not exist with `using P = int*`
# and is therefore treated as a bug in the original code, not in the formatter.
# If a rewrite changes meaning, it reveals a preprocessor-based type that should
# be replaced with a proper alias or renamed to make its intent explicit.
QualifierAlignment: Right
