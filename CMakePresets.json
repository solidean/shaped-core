{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21
    },
    "configurePresets": [
        {
            "name": "x64-windows-base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "binaryDir": "${sourceDir}/build/${presetName}",
            "hidden": true
        },
        {
            "name": "x64-windows-msvc-ninja-base",
            "inherits": "x64-windows-base",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "cl",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER_LAUNCHER": "${sourceDir}/tools/bin/diag-launcher.exe",
                "CMAKE_CXX_COMPILER_LAUNCHER": "${sourceDir}/tools/bin/diag-launcher.exe",
                "CMAKE_C_LINKER_LAUNCHER": "${sourceDir}/tools/bin/diag-launcher.exe",
                "CMAKE_CXX_LINKER_LAUNCHER": "${sourceDir}/tools/bin/diag-launcher.exe"
            },
            "generator": "Ninja",
            "hidden": true
        },
        {
            "name": "x64-windows-msvc-ninja-debug",
            "displayName": "Debug MSVC (Ninja)",
            "description": "Debug build with full symbols",
            "inherits": "x64-windows-msvc-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "x64-windows-msvc-ninja-release",
            "displayName": "Release MSVC (Ninja)",
            "description": "Optimized release build",
            "inherits": "x64-windows-msvc-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "x64-windows-msvc-ninja-relwithdebinfo",
            "displayName": "RelWithDebInfo MSVC (Ninja)",
            "description": "Optimized build with debug symbols",
            "inherits": "x64-windows-msvc-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "x64-windows-clang-ninja-base",
            "inherits": "x64-windows-base",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang-cl",
                "CMAKE_C_COMPILER": "clang-cl",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER_LAUNCHER": "${sourceDir}/tools/bin/diag-launcher.exe",
                "CMAKE_CXX_COMPILER_LAUNCHER": "${sourceDir}/tools/bin/diag-launcher.exe",
                "CMAKE_C_LINKER_LAUNCHER": "${sourceDir}/tools/bin/diag-launcher.exe",
                "CMAKE_CXX_LINKER_LAUNCHER": "${sourceDir}/tools/bin/diag-launcher.exe"
            },
            "generator": "Ninja",
            "hidden": true
        },
        {
            "name": "x64-windows-clang-ninja-debug",
            "displayName": "Debug Clang (Ninja, Windows)",
            "description": "Debug build with full symbols",
            "inherits": "x64-windows-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "x64-windows-clang-ninja-release",
            "displayName": "Release Clang (Ninja, Windows)",
            "description": "Optimized release build",
            "inherits": "x64-windows-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "x64-windows-clang-ninja-relwithdebinfo",
            "displayName": "RelWithDebInfo Clang (Ninja, Windows)",
            "description": "Optimized build with debug symbols",
            "inherits": "x64-windows-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "x64-linux-base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            },
            "hidden": true
        },
        {
            "name": "x64-linux-clang-ninja-base",
            "inherits": "x64-linux-base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            },
            "hidden": true
        },
        {
            "name": "x64-linux-gcc-ninja-relwithdebinfo",
            "displayName": "RelWithDebInfo GCC (Ninja, Linux)",
            "description": "Optimized build with debug symbols",
            "inherits": "x64-linux-base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "x64-linux-clang-ninja-debug",
            "displayName": "Debug Clang (Ninja, Linux)",
            "description": "Debug build with full symbols",
            "inherits": "x64-linux-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "x64-linux-clang-ninja-release",
            "displayName": "Release Clang (Ninja, Linux)",
            "description": "Optimized release build",
            "inherits": "x64-linux-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "x64-linux-clang-ninja-relwithdebinfo",
            "displayName": "RelWithDebInfo Clang (Ninja, Linux)",
            "description": "Optimized build with debug symbols",
            "inherits": "x64-linux-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "x64-linux-clang-ninja-sanitize-address-undefined",
            "displayName": "Sanitize Address+Undefined Clang (Ninja, Linux)",
            "description": "Debug build with address and undefined behavior sanitizers",
            "inherits": "x64-linux-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SANITIZE": "address,undefined"
            }
        },
        {
            "name": "x64-windows-clang-ninja-coverage",
            "displayName": "Coverage Clang (Ninja, Windows)",
            "description": "RelWithDebInfo build with LLVM source-based coverage instrumentation",
            "inherits": "x64-windows-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "SC_COVERAGE": "ON"
            }
        },
        {
            "name": "x64-linux-clang-ninja-coverage",
            "displayName": "Coverage Clang (Ninja, Linux)",
            "description": "RelWithDebInfo build with LLVM source-based coverage instrumentation",
            "inherits": "x64-linux-clang-ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "SC_COVERAGE": "ON"
            }
        },
        {
            "name": "macos-arm-llvm-coverage",
            "displayName": "Coverage Clang (macOS ARM)",
            "description": "RelWithDebInfo build with LLVM source-based coverage instrumentation",
            "inherits": "macos-arm-llvm-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "SC_COVERAGE": "ON"
            }
        },
        {
            "name": "macos-arm-llvm-base",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
                "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "CMAKE_EXE_LINKER_FLAGS": "-L/opt/homebrew/opt/llvm/lib/c++ -lc++abi",
                "CMAKE_SHARED_LINKER_FLAGS": "-L/opt/homebrew/opt/llvm/lib/c++ -lc++abi"
            },
            "hidden": true
        },
        {
            "name": "macos-arm-llvm-debug",
            "displayName": "macOS ARM Debug",
            "description": "Debug build with full symbols",
            "inherits": "macos-arm-llvm-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "macos-arm-llvm-release",
            "displayName": "macOS ARM Release",
            "description": "Optimized release build",
            "inherits": "macos-arm-llvm-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "macos-arm-llvm-relwithdebinfo",
            "displayName": "macOS ARM RelWithDebInfo",
            "description": "Optimized build with debug symbols",
            "inherits": "macos-arm-llvm-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "android-ndk-arm64-base",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "C:/Android/android-ndk-r27c/build/cmake/android.toolchain.cmake",
                "ANDROID_ABI": "arm64-v8a",
                "ANDROID_PLATFORM": "android-21",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            },
            "hidden": true
        },
        {
            "name": "android-ndk-arm64-debug",
            "displayName": "Android NDK arm64-v8a Debug",
            "description": "Debug build targeting Android arm64-v8a via NDK r27c",
            "inherits": "android-ndk-arm64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "android-ndk-arm64-release",
            "displayName": "Android NDK arm64-v8a Release",
            "description": "Optimized release build targeting Android arm64-v8a via NDK r27c",
            "inherits": "android-ndk-arm64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "android-ndk-arm64-relwithdebinfo",
            "displayName": "Android NDK arm64-v8a RelWithDebInfo",
            "description": "Optimized build with debug symbols targeting Android arm64-v8a via NDK r27c",
            "inherits": "android-ndk-arm64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug-msvc",
            "configurePreset": "x64-windows-msvc-ninja-debug"
        },
        {
            "name": "release-msvc",
            "configurePreset": "x64-windows-msvc-ninja-release"
        },
        {
            "name": "relwithdebinfo-msvc",
            "configurePreset": "x64-windows-msvc-ninja-relwithdebinfo"
        },
        {
            "name": "debug-clang",
            "configurePreset": "x64-windows-clang-ninja-debug"
        },
        {
            "name": "release-clang",
            "configurePreset": "x64-windows-clang-ninja-release"
        },
        {
            "name": "relwithdebinfo-clang",
            "configurePreset": "x64-windows-clang-ninja-relwithdebinfo"
        },
        {
            "name": "debug-linux-clang",
            "configurePreset": "x64-linux-clang-ninja-debug"
        },
        {
            "name": "release-linux-clang",
            "configurePreset": "x64-linux-clang-ninja-release"
        },
        {
            "name": "relwithdebinfo-linux-clang",
            "configurePreset": "x64-linux-clang-ninja-relwithdebinfo"
        },
        {
            "name": "relwithdebinfo-linux-gcc",
            "configurePreset": "x64-linux-gcc-ninja-relwithdebinfo"
        },
        {
            "name": "coverage-clang",
            "configurePreset": "x64-windows-clang-ninja-coverage"
        },
        {
            "name": "coverage-linux-clang",
            "configurePreset": "x64-linux-clang-ninja-coverage"
        },
        {
            "name": "coverage-macos-arm-llvm",
            "configurePreset": "macos-arm-llvm-coverage"
        },
        {
            "name": "macos-arm-llvm-debug",
            "configurePreset": "macos-arm-llvm-debug"
        },
        {
            "name": "macos-arm-llvm-release",
            "configurePreset": "macos-arm-llvm-release"
        },
        {
            "name": "macos-arm-llvm-relwithdebinfo",
            "configurePreset": "macos-arm-llvm-relwithdebinfo"
        },
        {
            "name": "android-ndk-arm64-debug",
            "configurePreset": "android-ndk-arm64-debug"
        },
        {
            "name": "android-ndk-arm64-release",
            "configurePreset": "android-ndk-arm64-release"
        },
        {
            "name": "android-ndk-arm64-relwithdebinfo",
            "configurePreset": "android-ndk-arm64-relwithdebinfo"
        }
    ]
}
